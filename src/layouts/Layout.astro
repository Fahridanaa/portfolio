---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Fahridana Ahmad Rayyansyah's casual software portfolio."
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#fbfaf2" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		<a
			href="#main-content"
			class="depth-control fixed left-4 top-4 z-[60] -translate-y-20 rounded-md bg-brand-paper px-4 py-2 font-semibold text-brand-ink transition-transform duration-200 focus-visible:translate-y-0">
			Skip To Content
		</a>
		<main id="main-content" class="relative min-h-dvh">
			<slot />
		</main>
	</body>
</html>
<style is:global>
	html {
		scroll-behavior: smooth;
		scrollbar-gutter: stable;
	}

	::-webkit-scrollbar {
		width: 10px;
	}

	::-webkit-scrollbar-track {
		background: #eef3e8;
	}

	::-webkit-scrollbar-thumb {
		background-color: #2e5c37;
		border-radius: 10px;
		box-shadow: inset 0 0 0 2px #eef3e8;
	}

	::-webkit-scrollbar-button {
		display: none;
	}
</style>
