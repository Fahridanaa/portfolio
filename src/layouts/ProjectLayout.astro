---
import type { ProjectMeta } from "@/models/project";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import ProjectButton from "@/components/ui/ProjectButton";
import { Code } from "lucide-react";
import TechStack from "@/components/ui/TechStack.astro";

export type Props = {
	frontmatter: ProjectMeta;
	slug: string;
};
const { frontmatter, slug } = Astro.props as Props;
---

<Layout title={frontmatter.title}>
	<div
		class="notebook-sheet mx-auto min-h-dvh w-full max-w-6xl overflow-hidden px-5 sm:px-8 lg:px-12">
		<article class="notebook-section mx-auto max-w-5xl">
			<a
				href="/"
				class="ink-button mb-10 inline-flex min-h-11 items-center justify-center rounded-sm bg-brand-paper/90 px-5 py-3 font-black uppercase tracking-normal text-brand-ink transition-[transform,box-shadow,background-color] duration-150 hover:bg-brand-green-soft">
				Back To Home
			</a>
			<section class="flex flex-col gap-8">
				<div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
					<div class="space-y-3">
						<p class="sketch-label">{frontmatter.type}</p>
						<h1
							class="max-w-[12ch] text-pretty text-5xl font-black leading-[0.98] text-brand-ink sm:text-6xl">
							{frontmatter.title}
						</h1>
					</div>
					<div class="flex flex-wrap gap-3">
						{
							frontmatter.sourceClient && (
								<ProjectButton
									href={frontmatter.sourceClient}
									icon={Code}
									text="Client"
								/>
							)
						}
						{
							frontmatter.sourceServer && (
								<ProjectButton
									href={frontmatter.sourceServer}
									icon={Code}
									text="API"
								/>
							)
						}
					</div>
				</div>
				<div class="camera-print">
					<span class="camera-pin" aria-hidden="true"></span>
					<Image
						src={`/assets/projects/${slug}/cover.webp`}
						alt={frontmatter.title}
						loading="eager"
						width={1600}
						height={800}
						class="w-full rounded-sm"
					/>
					<p class="camera-caption">project cover</p>
				</div>
			</section>
			<section class="soft-divider mt-8 py-5">
				<div class="flex flex-wrap gap-2">
					{
						frontmatter.stack.map((tech: string) => (
							<TechStack tech={tech} size="small" isLazy={false} />
						))
					}
				</div>
			</section>
			<section
				class="prose prose-lg relative mt-8 max-w-none break-words text-brand-graphite prose-headings:text-brand-ink prose-a:text-brand-green prose-strong:text-brand-ink prose-ul:list-disc">
				<slot />
			</section>
		</article>
	</div>
</Layout>
