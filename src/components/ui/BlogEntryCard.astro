---
import BlogTags from "@/components/ui/BlogTags.astro";
import {
	estimateReadingTime,
	formatBlogDate,
	type BlogEntry,
} from "@/utils/blog";

interface Props {
	entry: BlogEntry;
	variant?: "compact" | "featured";
	index?: number;
}

const { entry, variant = "compact", index = 0 } = Astro.props;
const readingTime = estimateReadingTime(entry.body);
const isFeatured = variant === "featured";
const stickyNoteClasses = [
	"sticky-note-left",
	"sticky-note-center",
	"sticky-note-right",
	"sticky-note-blue-left",
	"sticky-note-pink-center",
	"sticky-note-yellow-right",
];
const tiltClass = stickyNoteClasses[index % stickyNoteClasses.length];
---

<a href={`/blog/${entry.slug}`}
	class={`sticky-note sticky-note-lift no-underline ${tiltClass} flex min-h-72 flex-col p-5 ${isFeatured ? "sm:min-h-80 sm:p-6" : ""}`}>
	<div class="relative z-[1] flex flex-1 flex-col gap-4">
		<div class="flex flex-1 flex-col gap-4">
			<div class="flex flex-wrap items-center gap-2 font-mono text-[0.68rem] font-bold uppercase tracking-normal text-brand-graphite">
				<time datetime={entry.data.date.toISOString()}>
					{formatBlogDate(entry.data.date)}
				</time>
				<span aria-hidden="true">/</span>
				<span>{readingTime} min read</span>
				{entry.data.draft && <span class="sketch-label text-[0.62rem]">draft</span>}
			</div>
			<div class="space-y-3">
				<h3
					class={`text-pretty font-black leading-tight text-brand-ink ${
						isFeatured ? "text-3xl sm:text-4xl" : "text-2xl"
					}`}>
					{entry.data.title}
				</h3>
				<BlogTags tags={entry.data.tags} size="small" />
				<p class="compact-copy break-words text-sm leading-relaxed text-brand-graphite">
					{entry.data.description}
				</p>
			</div>
		</div>
	</div>
</a>
