---
import { normalizeTag } from "@/utils/blog";

interface Props {
	tags: string[];
	size?: "small" | "normal";
}

const { tags, size = "normal" } = Astro.props;
---

{
	tags.length > 0 && (
		<ul class="flex flex-wrap gap-x-3 gap-y-1" aria-label="Blog tags">
			{tags.map((tag) => (
				<li>
					<span
						class={`font-mono font-bold lowercase tracking-normal text-brand-graphite ${
							size === "small"
								? "text-[0.72rem]"
								: "text-sm"
						}`}
					>
						{normalizeTag(tag)}
					</span>
				</li>
			))}
		</ul>
	)
}
