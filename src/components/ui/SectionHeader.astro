---
interface Props {
	title?: string;
	variant?: "default" | "centered";
	spacer?: boolean;
}

const { title, variant = "default", spacer = false } = Astro.props;
---

<section
	class={`section-heading flex items-center gap-3 ${variant === "centered" ? "justify-center" : ""} ${spacer ? "md:pr-56" : ""}`}>
	{variant === "centered" && (
		<div class="soft-rule hidden flex-1 md:block"></div>
	)}
	<div class="flex min-w-0 items-center gap-3">
		<span
			class="depth-chip hidden h-4 w-4 rotate-3 rounded-sm bg-brand-highlighter sm:block"
			aria-hidden="true">
		</span>
		<h2
			class="text-pretty text-2xl font-black uppercase tracking-normal text-brand-ink sm:text-3xl">
			<slot>{title}</slot>
		</h2>
	</div>
	<div class="soft-rule flex-1"></div>
</section>
