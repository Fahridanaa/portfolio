---
interface Props {
	languages?: Array<{
		greeting: string;
		language: string;
	}>;
}

const { languages = [] } = Astro.props;
---

<div
	id="splash-screen"
	class="splash-screen fixed inset-0 z-50 flex items-center justify-center bg-brand-paper opacity-0 pointer-events-none">
	<div class="paper-scrap px-10 py-8 text-center text-brand-ink">
		<div id="greeting" class="text-4xl font-black mb-4"></div>
		<div id="language" class="text-xl font-semibold text-brand-graphite"></div>
	</div>
</div>

<script is:inline define:vars={{ languages }}>
	document.addEventListener("DOMContentLoaded", () => {
		const splashScreen = document.getElementById("splash-screen");
		const greetingElement = document.getElementById("greeting");
		const languageElement = document.getElementById("language");

		if (!splashScreen || !greetingElement || !languageElement || !languages.length) {
			return;
		}

		const prefersReducedMotion = window.matchMedia(
			"(prefers-reduced-motion: reduce)"
		).matches;

		if (prefersReducedMotion) {
			splashScreen.remove();
			return;
		}

		splashScreen.classList.remove("opacity-0", "pointer-events-none");

		document.body.classList.add("overflow-hidden");

		let currentIndex = 0;

		function cycleGreetings() {
			const current = languages[currentIndex];
			greetingElement.textContent = current.greeting;
			languageElement.textContent = current.language;

			currentIndex++;

			if (currentIndex >= languages.length) {
				clearInterval(greetingInterval);

				setTimeout(() => {
					document.body.classList.remove("overflow-hidden");
					setTimeout(() => {
						splashScreen.classList.add("-translate-y-full");

						setTimeout(() => {
							splashScreen.remove();
						}, 500);
					}, 400);
				}, 400);
			}
		}

		cycleGreetings();
		const greetingInterval = setInterval(cycleGreetings, 200);
	});
</script>

<style>
	.splash-screen {
		background:
			linear-gradient(rgba(91, 126, 164, 0.16) 1px, transparent 1px) 0 0 / 28px 28px,
			linear-gradient(90deg, rgba(91, 126, 164, 0.16) 1px, transparent 1px) 0 0 / 28px 28px,
			#fbfaf2;
		transition:
			transform 0.5s ease-out,
			opacity 0.5s ease-out;
	}
</style>
